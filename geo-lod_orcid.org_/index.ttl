@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix void: <http://rdfs.org/ns/void#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://w3id.org/geo-lod/geo-lod_orcid.org_> a void:Linkset,
        <http://www.w3.org/ns/ldp#Resource>,
        <https://www.iana.org/assignments/media-types/text/turtle#Resource> ;
    rdfs:label "Linkset: geo-lod - orcid.org"@en,
        "Linkset: geo-lod - orcid:"@en ;
    void:linkPredicate dcterms:creator,
        dcterms:rightsHolder,
        prov:wasAssociatedWith,
        prov:wasAttributedTo ;
    void:objectsTarget <http://orcid.org/>,
        <https://orcid.org/> ;
    void:subjectsTarget <http://w3id.org/geo-lod/geo-lod> ;
    void:triples 74,
        148 .


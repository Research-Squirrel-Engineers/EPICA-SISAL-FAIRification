@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix void: <http://rdfs.org/ns/void#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://w3id.org/geo-lod/geo-lod_sws.geonames.org_> a void:Linkset,
        <http://www.w3.org/ns/ldp#Resource>,
        <https://www.iana.org/assignments/media-types/text/turtle#Resource> ;
    rdfs:label "Linkset: geo-lod - gns:"@en,
        "Linkset: geo-lod - sws.geonames.org"@en ;
    void:linkPredicate <http://fuzzy-sl.squirrel.link/ontology/dubiousMatch>,
        <http://fuzzy-sl.squirrel.link/ontology/partlyMatch>,
        <http://fuzzy-sl.squirrel.link/ontology/spatialCloseMatch>,
        skos:closeMatch ;
    void:objectsTarget <http://sws.geonames.org/>,
        <https://sws.geonames.org/> ;
    void:subjectsTarget <http://w3id.org/geo-lod/geo-lod> ;
    void:triples 1,
        2,
        4,
        5,
        10 .

